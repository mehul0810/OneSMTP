{
  "name": "onesmtp/onesmtp",
  "description": "OneSMTP WordPress plugin",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "php-stubs/wordpress-stubs": "^6.8",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "OneSMTP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OneSMTP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=phpcs.xml.dist",
    "lint:fix": "phpcbf --standard=phpcs.xml.dist",
    "test": "phpunit --configuration phpunit.xml.dist",
    "analyze": "phpstan analyse --configuration=phpstan.neon --no-progress",
    "perf:smoke": "./scripts/benchmarks/run-baseline.sh smoke",
    "ci": [
      "@lint",
      "@test",
      "@analyze"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
